# Groq API Key
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Database — start locally with: docker compose -f docker/docker-compose.yml up -d
DATABASE_URL=postgresql://postgres:password@localhost:5432/dailydigest

# Gmail SMTP — email delivery
# Use a Gmail App Password (NOT your regular password)
# Google Account → Security → 2-Step Verification → App passwords
GMAIL_SENDER=you@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# Digest recipient
# The email address that receives the daily digest.
# To send to multiple people in the future, this becomes a DB table.
DIGEST_RECIPIENT_EMAIL=you@example.com